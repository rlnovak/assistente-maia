# === LLM ===
LLM_PROVIDER=openai            # anthropic | openai
LLM_MODEL=gpt-5.4              # claude-sonnet-4-5 | claude-haiku-4-5-20251001 | gpt-5.4 | gpt-5.4-mini

# === API Keys ===
ANTHROPIC_API_KEY=             # sempre presente (troca de provider sem reconfigurar)
OPENAI_API_KEY=                # usado para LLM e embeddings

# === Embeddings (TRAVADO — não mudar sem reingerir todo o knowledge/) ===
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# === Vector Store ===
VECTOR_STORE_BACKEND=local     # local | pinecone
CHROMA_PATH=./.chroma
CHROMA_COLLECTION=maia-rag

# === Supabase ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# === Email (não testado em dev) ===
RESEND_API_KEY=

# === Stories LLM (independente do chat — pode usar provider diferente) ===
STORIES_LLM_PROVIDER=anthropic  # anthropic | openai | qwen
STORIES_LLM_MODEL=claude-sonnet-4-5  # qwen: qwen-plus | qwen-max | qwen-turbo

# === Qwen / DashScope (obrigatória se STORIES_LLM_PROVIDER=qwen) ===
DASHSCOPE_API_KEY=

# === ElevenLabs (geração de áudio — deixar vazio até ter a key) ===
ELEVENLABS_API_KEY=

# === Storage (áudios das histórias) ===
SUPABASE_STORAGE_BUCKET_AUDIOS=story-audios
AUDIO_EXPIRY_DAYS=7

# === App ===
ENV=development

# === Pinecone (só necessário se VECTOR_STORE_BACKEND=pinecone) ===
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_ENVIRONMENT=
